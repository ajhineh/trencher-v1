{
    "network": "testnet",
    "rpcUrl": "https://api.testnet.solana.com",
    "trading": {
        "enabled": false,
        "maxPositionSizeSol": 0.1,
        "maxDailyTrades": 5,
        "maxTotalExposureSol": 0.5,
        "minLiquidityUsd": 5000,
        "maxTokenAge": 3600000
    },
    "riskManagement": {
        "level": "CONSERVATIVE",
        "stopLossPercentage": 5,
        "takeProfitPercentage": 10,
        "maxSlippage": 2,
        "minConfidenceScore": 70
    },
    "monitoring": {
        "enableLogging": true,
        "logLevel": "debug",
        "enableAlerts": true,
        "alertThresholds": {
            "minBalance": 0.5,
            "maxLoss": 0.2,
            "errorRate": 0.1
        }
    },
    "performance": {
        "cacheDuration": 60000,
        "maxConcurrentAnalysis": 3,
        "requestTimeout": 30000
    }
}