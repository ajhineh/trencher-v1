// .env.sniper.example

# ═══════════════════════════════════════════════════════════
# ULTIMATE SNIPER SYSTEM - Configuration
# ═══════════════════════════════════════════════════════════

# Enable Ultimate Sniper System
ENABLE_ULTIMATE_SNIPER=true

# AI Sniper Configuration
AI_CONFIDENCE_THRESHOLD=70
MAX_BUY_AMOUNT=0.01
MIN_LIQUIDITY_SOL=1
LLM_CONCURRENCY_LIMIT=2 # Max concurrent requests to OpenAI

# Multi-Wallet Configuration (optional - for better bundles)
# Leave empty to use only main wallet
WALLET_2_PRIVATE_KEY=
WALLET_3_PRIVATE_KEY=

# Rug Pull Protection
ENABLE_RUG_PROTECTION=true
MONITOR_TOP_HOLDERS_COUNT=5

# Jito Configuration
JITO_TIP_AMOUNT=0.001
JITO_EMERGENCY_TIP=0.01

# Intelligent Selling
ENABLE_INTELLIGENT_SELLING=true
TRAILING_STOP_PERCENT=15
PROFIT_TARGET_1=50
PROFIT_TARGET_2=100
PROFIT_TARGET_3=200

# Pre-Build Bundle
ENABLE_PREBUILD_BUNDLE=true
AUTO_UPDATE_BUNDLE=true

# WebSocket Monitoring
WEBSOCKET_DETECTION=true
DETECTION_INTERVAL_MS=5000

# Data Sources (Sentiment & News)
CRYPTOPANIC_API_KEY=
TWITTER_BEARER_TOKEN=
ENABLE_RSS_NEWS=true
