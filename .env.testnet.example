# Testnet Environment Configuration

# Solana Configuration
SOLANA_RPC_URL=https://api.testnet.solana.com
SOLANA_WALLET_PATH=~/.config/solana/testnet-wallet.json
NETWORK=testnet

# Trading Configuration
MAX_POSITION_SIZE_SOL=0.1
MAX_DAILY_TRADES=5
MAX_TOTAL_EXPOSURE_SOL=0.5
ENABLE_TRADING=false

# Risk Management
RISK_LEVEL=CONSERVATIVE
STOP_LOSS_PERCENTAGE=5
TAKE_PROFIT_PERCENTAGE=10
MAX_SLIPPAGE=2

# AI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Monitoring
ENABLE_LOGGING=true
LOG_LEVEL=debug
ENABLE_ALERTS=true
ALERT_WEBHOOK_URL=

# Performance
CACHE_DURATION_MS=60000
MAX_CONCURRENT_ANALYSIS=3

# Pumpswap Configuration
PUMPSWAP_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
PUMPSWAP_GLOBAL_STATE=4wTV1YmiEkRvAtNtsSGPtUrqRYQMe5SKy2uB4Jjaxnjf

# Database (Optional)
DB_ENABLED=false
DB_PATH=./data/testnet.db
