# AI Trading Agent - Environment Variables

# OpenAI API Key (optional - system works without it in rule-based mode)
OPENAI_API_KEY=sk-your-api-key-here

# AI Configuration
AI_MODEL=gpt-4-turbo-preview
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=1000

# Trading Configuration
MIN_AI_CONFIDENCE=70
MAX_LEVERAGE=5
MAX_POSITION_SIZE_PERCENT=2

# Risk Management
ENABLE_AI_AGENT=true
CONSERVATIVE_MODE=true
