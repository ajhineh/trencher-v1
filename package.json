{
  "name": "trencher",
  "version": "0.0.2",
  "description": "Trencher V2 - CEX Futures High Frequency Micro-Tick Scalper Bot",
  "main": "dist/trencher.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/trencher.js",
    "dev": "ts-node src/trencher.ts",
    "dev:ui": "cd dashboard-ui && npm run dev",
    "build:ui": "cd dashboard-ui && npm run build",
    "report": "node scripts/generate_report.js",
    "report:microtick": "node scripts/generate_report.js --source microtick_history.json --output microtick_report.html",
    "reset": "node scripts/reset_history.js",
    "reset:microtick": "node scripts/reset_microtick.js",
    "analyze": "node scripts/analyze_trades.js",
    "analyze:all": "node scripts/analyze_trades.js --all"
  },
  "keywords": [],
  "author": "Erbsensuppee",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.16.1",
    "ccxt": "^4.5.28",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "telegraf": "^4.16.3",
    "winston": "^3.18.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}